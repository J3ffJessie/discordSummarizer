{
  "name": "discord-summarizer",
  "version": "1.1.0",
  "main": "index.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node ./src/index.js",
    "dev": "nodemon ./src/index.js",
    "register-commands": "node register-commands.js",
    "test": "jest --verbose --colors",
    "test:watch": "jest --watch --verbose --colors",
    "test:report": "jest --verbose --colors",
    "test:dashboard": "jest --verbose --colors --runInBand --detectOpenHandles --testLocationInResults"
  },
  "jest": {
    "reporters": [
      "default",
      [
        "jest-stare",
        {
          "resultDir": "jest-stare",
          "reportTitle": "Discord Summarizer Test Report",
          "coverageLink": "../coverage/lcov-report/index.html",
          "additionalResultsProcessors": []
        }
      ]
    ],
    "verbose": true,
    "collectCoverage": true,
    "coverageDirectory": "coverage",
    "testEnvironment": "node"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@discordjs/voice": "^0.19.2",
    "@noble/ciphers": "^2.1.1",
    "axios": "^1.9.0",
    "better-sqlite3": "^12.6.2",
    "discord.js": "^14.19.2",
    "dotenv": "^16.5.0",
    "groq-sdk": "^0.23.0",
    "libsodium-wrappers": "^0.7.15",
    "node-cron": "^3.0.3",
    "openai": "^6.25.0",
    "opusscript": "^0.0.8",
    "prism-media": "^1.3.5",
    "undici": "^7.14.0",
    "wav": "^1.0.2",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "jest": "^30.2.0",
    "jest-stare": "^2.5.3"
  }
}
