# ── Required ──────────────────────────────────────────────────────────────────

# Discord bot token and application ID (from Discord Developer Portal)
DISCORD_TOKEN=
CLIENT_ID=

# Public URL of this service — used to generate /setup dashboard links.
# Local dev: http://localhost:3000
# Production (Render): https://your-app.onrender.com
PUBLIC_URL=

# Path where the database and data files are stored.
# On Render: set to /data (your persistent disk mount path)
# Local dev: leave unset (defaults to src/data/)
# DATA_DIR=/data

# ── Optional ──────────────────────────────────────────────────────────────────

# Your Discord user ID — the bot will DM you error alerts
# ADMIN_USER_ID=

# Comma-separated Discord user IDs allowed to run bot-owner commands
# (e.g. /server-summary, /coffee-pair)
# ALLOWED_USER_IDS=

# Public URL for the live voice captions page.
# Only needed if using the /translate voice translation feature.
# Can be the same value as PUBLIC_URL.
# CAPTION_URL=

# HTTP server port — set automatically by Render, defaults to 3000
# PORT=3000

# ── Local testing only ────────────────────────────────────────────────────────

# Your test server ID — used when registering commands to a single guild
# (faster than global registration during development)
# See src/commands/register.js for how to switch between guild and global registration
# GUILD_ID=

# ── AI provider fallback (optional) ──────────────────────────────────────────
#
# Each server admin configures their own AI provider and API key through the
# /setup dashboard — no shared key is needed or recommended here.
#
# You can set GROQ_API_KEY as a fallback for local development/testing only.
# Do NOT set this in production — each guild should supply their own key.
# GROQ_API_KEY=
