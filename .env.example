# Discord bot tokens and IDs
DISCORD_TOKEN=
CLIENT_ID=
GUILD_ID=
# ADMIN_USER_ID=

# Groq API key — used as the fallback for all AI services if no provider-specific key is set.
# Summarization defaults to Groq so you can provide a shared key here.
# Translation requires a key — set it here or per-guild via /setup ai.
GROQ_API_KEY=

# ─── AI Provider Configuration ───────────────────────────────────────────────
# Each AI task (summarization, translation, transcription) can use a different
# provider. Configure globally here, or let guild admins override via /setup ai.
#
# Supported providers:
#   groq       — Groq API (default, fast, free tier available)
#   openai     — OpenAI API
#   anthropic  — Anthropic Claude API
#   ollama     — Local Ollama instance (OpenAI-compatible, no API key needed)
#   custom     — Any OpenAI-compatible endpoint (set the base URL below)
#
# Summarization — defaults to Groq + GROQ_API_KEY if unset
# SUMM_PROVIDER=groq
# SUMM_API_KEY=          # falls back to GROQ_API_KEY
# SUMM_MODEL=            # e.g. llama-3.1-8b-instant, gpt-4o-mini, claude-haiku-4-5-20251001
# SUMM_BASE_URL=         # required for ollama / custom
#
# Translation — defaults to Groq + GROQ_API_KEY if unset
# Guild admins should configure their own key via /setup ai service:translation
# TRANS_PROVIDER=groq
# TRANS_API_KEY=         # falls back to GROQ_API_KEY
# TRANS_MODEL=
# TRANS_BASE_URL=
#
# Transcription (voice-to-text) — Groq and OpenAI Whisper supported
# TRANS_PROVIDER and OpenAI are the only providers with Whisper-compatible APIs
# STT_PROVIDER=groq
# STT_API_KEY=           # falls back to GROQ_API_KEY
# STT_MODEL=             # whisper-large-v3-turbo (groq) or whisper-1 (openai)
# STT_BASE_URL=
# ─────────────────────────────────────────────────────────────────────────────

# Optional: Luma API key (if using events)
# LUMA_API_KEY=

# Server summary settings
# Channel ID where the weekly summary is posted
TARGET_CHANNEL_ID=
# Cron expression for server summary (default: Mondays at 10:00)
SERVER_SUMMARY_CRON=0 10 * * 1

# Coffee pairing settings
COFFEE_ROLE_NAME=coffee chat
COFFEE_CRON_SCHEDULE=0 9 * * 1
COFFEE_PAIRING_COOLDOWN_DAYS=30
# Set to true to run coffee pairing every other Monday instead of every Monday.
# Fires on even ISO week numbers (2, 4, 6 …). The cron schedule still needs to
# be set to weekly (e.g. 0 5 * * 1) — the skip logic is handled in code.
COFFEE_BIWEEKLY=true

# Timezone for all cron jobs — must be a valid IANA timezone string.
# Render runs UTC by default. Set this so jobs fire at your intended local time.
# Examples: America/New_York, America/Chicago, America/Los_Angeles, Europe/London
CRON_TIMEZONE=UTC

# App port
PORT=3000

# Public URL of this service — used to generate the captions link posted in Discord.
# On Render this is your service URL, e.g. https://your-app.onrender.com
# If unset, the link defaults to http://localhost:3000 (wrong for production).
CAPTION_URL=
